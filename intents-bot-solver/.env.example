# Testnet RPC endpoint
RPC_URL=https://your-testnet-rpc

# Chain id of the testnet network
CHAIN_ID=11155111

# Ayni contracts
AYNI_PROTOCOL_ADDRESS=0x0000000000000000000000000000000000000000
DESTINATION_SETTLER_ADDRESS=0x0000000000000000000000000000000000000000

# Solver wallet (funded with USDC + gas token)
SOLVER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# USDC token the solver is willing to spend for fills
USDC_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Polling and cursor
POLL_INTERVAL_SECS=5
MAX_BLOCK_RANGE=200
START_BLOCK=0
LAST_BLOCK_FILE=./last_block.json

# Optional minimum USDC balance guard (base units, e.g. 6 decimals)
# If set, bot pauses fills when wallet balance < this threshold.
MIN_USDC_BALANCE=0

# Logging
LOG_LEVEL=info
