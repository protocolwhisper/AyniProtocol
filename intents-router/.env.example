# ── EVM ───────────────────────────────────────────────────────────────────────
# LiteForge RPC endpoint
RPC_URL=https://liteforge.rpc.caldera.xyz/http

# Deployed AyniProtocol contract address (required)
AYNI_PROTOCOL_ADDRESS=0x0000000000000000000000000000000000000000

# LiteForge chain ID
CHAIN_ID=4441

# How often to poll for new blocks (seconds)
POLL_INTERVAL_SECS=5

# Block to start scanning from on first run.
# 0 = current latest minus 100 (safe default for a fresh deploy)
START_BLOCK=0

# ── NEAR Intents ──────────────────────────────────────────────────────────────
# JWT token from https://partners.near-intents.org
# Leave empty to use the unauthenticated tier (adds 0.2% fee to quotes)
NEAR_INTENTS_API_KEY=

# Solver Message Bus JWT (required for WebSocket subscribe/quote stream)
# This is different from the distribution-channel JWT used by NEAR_INTENTS_API_KEY.
NEAR_SOLVER_BUS_API_KEY=

# NEAR Intents Message Bus JSON-RPC endpoint
NEAR_INTENTS_RPC=https://solver-relay-v2.chaindefuser.com/rpc

# NEAR Intents Message Bus WebSocket endpoint
NEAR_INTENTS_WS=wss://solver-relay-v2.chaindefuser.com/ws

# Token address mapping: EVM hex address (lowercase, no 0x) → NEAR nep141 identifier
# JSON object as a single-line string.
# Example: {"a0b86991c6218b36c1d19d4a2e9eb0ce3606eb48":"nep141:usdc.near"}
TOKEN_MAP_JSON={}

# ── Service ───────────────────────────────────────────────────────────────────
# Structured log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Health endpoint port
PORT=8080

# ── Persistence ───────────────────────────────────────────────────────────────
# Path to the file that stores the last processed block number.
# Persisted across restarts to avoid re-scanning old blocks.
LAST_BLOCK_FILE=./last_block.json
